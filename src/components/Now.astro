---
import ReadingList from "../components/ReadingList.astro";
import ListeningList from "../components/ListeningList.astro";
import { reading } from "../data/now/reading";
import WorkingList from "../components/WorkingList.astro";
import { working } from "../data/now/working";
import { listening } from "../data/now/listening";
---

<section class="section section-now">
  <div class="container">
    <h2>Currently.</h2>
    <!-- <p>What I’m reading, listening to, and working on right now.</p> -->

    <div class="section-now__grid">
      <ReadingList items={reading} />
      <WorkingList items={working} />
      <ListeningList items={listening} />
    </div>
  </div>
</section>
