---
import type { ListeningItem } from "../content/now.types";

type Props = { items?: ListeningItem[] };
const { items = [] } = Astro.props as Props;

---

<div class="section-now__grid-item">
    <h3>Listening</h3>
        {items.length === 0 ? (
          <p class="muted">Nothing listed yet.</p>
        ) : (
          <ul class="listening-list">
            {items.map((item) => (
              <li class="listening-list__item">
                <div class="listening-list__content">
                  <strong>{item.title}</strong> by {item.artist}
                  {item.note ? <p class="listening-list__note">{item.note}</p> : null}
                  {item.link ? (
                    <p>
                      <a href={item.link} target="_blank" rel="noopener noreferrer">
                        Listen here
                      </a>
                    </p>
                  ) : null}
                </div>
              </li>
            ))}
          </ul>
        )}
</div>